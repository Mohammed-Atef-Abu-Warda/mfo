{
  "definition": {
    "ports": [
      {
        "port": 8000,
        "protocol": "http"
      }
    ],
    "routes": [
      {
        "path": "/",
        "port": 8000
      }
    ],
    "regions": [
      "fra"
    ],
    "scalings": [
      {
        "min": 1,
        "max": 1
      }
    ],
    "env": [
      {
        "key": "APP_ENV",
        "value": "production"
      },
      {
        "key": "APP_DEBUG",
        "value": "false"
      }
    ]
  }
}